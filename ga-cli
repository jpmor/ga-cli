def cmd_sessions(client: Client, args):
    for s in api.get_sessions(client):
        current = " (current)" if s.is_current else ""
        kind = "special" if s.type else "regular"
        print(f"{s.id:4d}  {s.library:12s}  {s.description}{current}")


def cmd_members(client: Client, args):
    session = _resolve_session(client, args.session)
    if args.id is not None:
        m = api.get_member(client, args.id, session.id)
        print(f"{m.title} {m.name} — District {m.district} ({m.party_name})")
        if m.residence:
            print(f"Residence: {m.residence}")
        if m.occupation:
            print(f"Occupation: {m.occupation}")
        if m.phone:
            print(f"Phone: {m.phone}")
        if m.committees:
            print(f"\nCommittees:")
            for c in m.committees:
                print(f"  {c.role:30s}  {c.name}")
    else:
        chamber = Chamber[args.chamber.title()] if args.chamber else None
        members = api.get_members(client, session.id, chamber)
        for m in sorted(members, key=lambda m: (m.chamber_type.value, int(''.join(filter(str.isdigit, m.district)) or 0))):
            print(f"{m.id:5d}  {m.chamber_type.name:6s}  {m.district:5s}  {m.party_name}  {m.city:20s}  {m.name}")


def cmd_committees(client: Client, args):
    session = _resolve_session(client, args.session)
    if args.id is not None:
        c = api.get_committee(client, args.id, session.id)
        print(f"{c.chamber.name} Committee on {c.name}")
        if c.phone:
            print(f"Phone: {c.phone}")
        if c.description:
            print(f"\n{c.description}")
        print(f"\nMembers ({len(c.members)}):")
        for m in c.members:
            print(f"  {m.role:30s}  {m.district:5s}  {m.name}")
        if c.subcommittees:
            print(f"\nSubcommittees:")
            for s in c.subcommittees:
                print(f"  {s}")
    else:
        chamber = Chamber[args.chamber.title()] if args.chamber else None
        committees = api.get_committees(client, session.id, chamber)
        for c in committees:
            print(f"{c.id:4d}  {c.chamber.name:6s}  {c.name}")


OCGA_DIR = os.path.join(REPO_ROOT, "docs", "ocga")


def _local_section_path(section_id: str) -> str:
    parts = section_id.lower().split("-", 2)
    return os.path.join(OCGA_DIR, parts[0], parts[1], f"{section_id.lower()}.md")


def _local_index_path(*parts) -> str:
    return os.path.join(OCGA_DIR, *[p.lower() for p in parts], "index.md")


def cmd_code(client: Client, args):
    if args.fetch:
        _cmd_codefetch(client, args)
        return

    renderer = MarkdownRenderer()
    id = args.id

    # No arg — list all 53 titles
    if id is None:
        renderer.print(open(_local_index_path()).read())
        return

    parts = id.split("-")

    # Single component — title TOC
    if len(parts) == 1:
        path = _local_index_path(parts[0])
        if not os.path.exists(path):
            print(f"Title {parts[0]} not fetched yet. Run: ./ga-cli code --fetch --title {parts[0]}", file=sys.stderr)
            sys.exit(1)
        renderer.print(open(path).read())
        return

    # Two components — chapter TOC
    if len(parts) == 2:
        path = _local_index_path(parts[0], parts[1])
        if not os.path.exists(path):
            print(f"Title {parts[0]} not fetched yet. Run: ./ga-cli code --fetch --title {parts[0]}", file=sys.stderr)
            sys.exit(1)
        renderer.print(open(path).read())
        return

    # Three or more — section text
    local = _local_section_path(id)
    if args.year:
        section = gacode.api.get_section(id, args.year)
        renderer.print(gacode.api.section_to_markdown(section))
        return
    if not os.path.exists(local):
        print(f"Section {id} not fetched yet. Run: ./ga-cli code --fetch --title {id.split('-')[0]}", file=sys.stderr)
        sys.exit(1)
    renderer.print(open(local).read())


def _fetch_chapter(chapter_dir, chapter_num, ch_name, title_num, sections, args):
    """Fetch all sections in one chapter. Runs in its own thread with its own HTTP session."""
    os.makedirs(chapter_dir, exist_ok=True)
    with open(os.path.join(chapter_dir, "index.md"), "w") as f:
        f.write(f"# {ch_name}\n\n")
        for sec_id, sec_name, _url in sections:
            f.write(f"- {sec_name}\n")

    print(f"  {ch_name} ({len(sections)} sections)", flush=True)

    written = skipped = 0
    for sec_id, sec_name, sec_url in sections:
        sec_file = os.path.join(chapter_dir, f"{sec_id}.md")

        if os.path.exists(sec_file):
            with open(sec_file) as f:
                content = f.read()
            body_lines = [l for l in content.splitlines() if l.strip() and not l.startswith("#")]
            if body_lines:
                skipped += 1
                continue

        try:
            section = gacode.api.get_section(sec_id, url=sec_url)
            with open(sec_file, "w") as f:
                f.write(gacode.api.section_to_markdown(section))
            written += 1
            print(f"    {sec_id}", flush=True)
        except Exception as e:
            print(f"    Warning: {sec_id}: {e}", file=sys.stderr, flush=True)

        time.sleep(args.delay + random.uniform(0, args.delay * 0.5))

    if skipped:
        print(f"    ({skipped} skipped, already fetched)", flush=True)


def _cmd_codefetch(client: Client, args):
    out = args.out or OCGA_DIR
    titles = api.get_code_titles(client)
    if args.title:
        titles = [t for t in titles if int(t.code) == args.title]
        if not titles:
            print(f"Error: title {args.title} not found.", file=sys.stderr)
            sys.exit(1)

    for title in titles:
        title_num = str(int(title.code))  # strip leading zero
        print(f"Title {title_num} — {title.name}", flush=True)

        time.sleep(args.delay)
        try:
            chapter_entries = gacode.api.get_title_toc(title_num)
        except Exception as e:
            print(f"  Warning: could not fetch TOC for title {title_num}: {e}", file=sys.stderr)
            continue

        title_dir = os.path.join(out, title_num)
        os.makedirs(title_dir, exist_ok=True)
        with open(os.path.join(title_dir, "index.md"), "w") as f:
            f.write(f"# Title {title_num} — {title.name}\n\n")
            for _, ch_name in chapter_entries:
                f.write(f"- {ch_name}\n")

        # Fetch chapter TOCs first (fast, sequential) to build the work list
        chapters = []
        for ch_path, ch_name in chapter_entries:
            slug = ch_path.rstrip("/").split("/")[-1]  # e.g. "chapter-11" or "article-1"
            chapter_num = slug[len("chapter-"):] if slug.startswith("chapter-") else slug
            chapter_dir = os.path.join(title_dir, chapter_num)
            try:
                sections = gacode.api.get_sections_for_chapter(title_num, chapter_num, delay=args.delay, chapter_path=ch_path)
                chapters.append((chapter_dir, chapter_num, ch_name, title_num, sections))
            except Exception as e:
                print(f"  Warning: could not fetch chapter {chapter_num}: {e}", file=sys.stderr)
            time.sleep(args.delay)

        if args.dry_run:
            for chapter_dir, chapter_num, ch_name, title_num, sections in chapters:
                for sec_id, *_ in sections:
                    print(f"  {os.path.join(chapter_dir, sec_id)}.md")
            continue

        gacode.client.set_initial_concurrency(args.workers)
        with concurrent.futures.ThreadPoolExecutor(max_workers=max(args.workers, 16)) as pool:
            futures = [pool.submit(_fetch_chapter, *ch_args, args=args) for ch_args in chapters]
            for f in concurrent.futures.as_completed(futures):
                if f.exception():
                    print(f"  Error: {f.exception()}", file=sys.stderr)


def cmd_bills(client: Client, args):
    # show — single bill detail
    if args.id is not None:
        bill = api.get_bill(client, args.id)
        print(f"{bill.label} — {bill.title}")
        print(f"Session:   {bill.session}")
        print(f"Status:    {bill.status}  (enacted={bill.status.is_enacted})")
        print(f"PDF:       {bill.pdf_url()}")
        print()
        print("Sponsors:")
        for s in sorted(bill.sponsors, key=lambda x: x.sequence):
            role = "primary" if s.sequence == 1 else "co-sponsor"
            print(f"  {s.name} ({s.district}) [{role}]")
        if bill.house_committee:
            print(f"House committee: {bill.house_committee.name}")
        if bill.senate_committee:
            print(f"Senate committee: {bill.senate_committee.name}")
        if bill.status_history:
            print()
            print("History:")
            for event in sorted(bill.status_history, key=lambda e: e.date):
                print(f"  {event}")
        if bill.first_reader:
            print()
            print("Summary:")
            print(f"  {bill.first_reader[:300]}")
        return

    session = _resolve_session(client, args.session)
    filters = {}
    if args.chamber:
        filters["chamberTypes"] = _chamber_filter(args.chamber)
    if args.doc_type:
        filters["documentTypes"] = _doctype_filter(args.doc_type)

    # fetch — write bills to markdown files
    if args.fetch:
        print(f"Session: {session}")
        out = args.out or os.path.join(REPO_ROOT, "legislation")
        total = written = skipped = 0

        for bill in api.search_bills(client, session.id, **filters):
            total += 1
            if args.enacted and not bill.status.is_enacted:
                skipped += 1
                continue

            try:
                full_bill = api.get_bill(client, bill.id)
            except Exception as e:
                print(f"  Warning: could not fetch detail for {bill.label}: {e}", file=sys.stderr)
                full_bill = bill

            text = ""
            try:
                text = api.get_bill_text(client, full_bill)
            except Exception as e:
                print(f"  Warning: could not fetch text for {full_bill.label}: {e}", file=sys.stderr)

            path = bill_path(full_bill, out)

            if args.dry_run:
                print(path)
                continue

            os.makedirs(os.path.dirname(path), exist_ok=True)
            with open(path, "w") as f:
                f.write(bill_to_markdown(full_bill, text))

            written += 1
            if written % 10 == 0:
                print(f"  {written} written ({full_bill.label})...")

            time.sleep(args.delay)

        print(f"\nDone. Total: {total}, written: {written}, skipped: {skipped}")
        return

    # list — search and print bills
    count = 0
    for bill in api.search_bills(client, session.id, **filters):
        if args.enacted and not bill.status.is_enacted:
            continue
        enacted_marker = " *" if bill.status.is_enacted else ""
        print(f"{bill.id:6d}  {bill.label:8s}  {bill.status.name:45s}  {bill.title[:60]}{enacted_marker}")
        count += 1
        if args.limit and count >= args.limit:
            break


# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        description="Georgia CLI",
    )
    sub = parser.add_subparsers(dest="command", required=False)

    # sessions
    sub.add_parser("sessions", help="List all legislative sessions")

    # members
    p = sub.add_parser("members", help="List members, or show detail for one")
    p.add_argument("id", type=int, nargs="?", help="Member ID (omit to list all)")
    p.add_argument("--session", type=int)
    p.add_argument("--chamber", choices=["house", "senate"])

    # committees
    p = sub.add_parser("committees", help="List committees, or show detail for one")
    p.add_argument("id", type=int, nargs="?", help="Committee ID (omit to list all)")
    p.add_argument("--session", type=int)
    p.add_argument("--chamber", choices=["house", "senate"])

    # bills
    p = sub.add_parser("bills", help="List bills, show detail for one, or fetch to markdown")
    p.add_argument("id", type=int, nargs="?", help="Legislation ID (omit to list)")
    p.add_argument("--session", type=int)
    p.add_argument("--chamber", choices=["house", "senate"])
    p.add_argument("--type", choices=["bill", "resolution"], dest="doc_type")
    p.add_argument("--enacted", action="store_true")
    p.add_argument("--limit", type=int)
    p.add_argument("--fetch", action="store_true", help="Write bills to markdown files")
    p.add_argument("--dry-run", action="store_true")
    p.add_argument("--out", help="Output base directory (default: legislation/)")
    p.add_argument("--delay", type=float, default=0.2)

    # code
    p = sub.add_parser("code", help="Browse Georgia Code, or fetch OCGA with --fetch")
    p.add_argument("id", nargs="?", help="Title (1), chapter (1-1), or section (1-1-1)")
    p.add_argument("--year", type=int, help="Code year (default: latest)")
    p.add_argument("--fetch", action="store_true", help="Fetch OCGA into ocga/")
    p.add_argument("--title", type=int, help="Fetch only this title number (with --fetch)")
    p.add_argument("--out", help="Output directory (default: ocga/)")
    p.add_argument("--dry-run", action="store_true")
    p.add_argument("--workers", type=int, default=1, help="Parallel chapter workers (default: 1)")
    p.add_argument("--delay", type=float, default=0.2, help="Base delay between requests per worker (jitter added)")

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        return

    client = Client()

    commands = {
        "sessions":   cmd_sessions,
        "members":    cmd_members,
        "committees": cmd_committees,
        "bills":      cmd_bills,
        "code":       cmd_code,
    }
    try:
        commands[args.command](client, args)
    except urllib.error.HTTPError as e:
        if e.code == 404:
            print(f"Error: not found.", file=sys.stderr)
        else:
            print(f"Error: HTTP {e.code}.", file=sys.stderr)
        sys.exit(1)
    except urllib.error.URLError as e:
        print(f"Error: {e.reason}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
