#!/usr/bin/env python3
"""
GA Legislature CLI.

Commands:
  code   [id] [--year]                  Browse Georgia Code
  code   --fetch [--title N] [--dry-run] [--out DIR]
                                        Fetch OCGA into ocga/
  bills  [id] [--session] [--chamber] [--type] [--enacted] [--limit]
                                        List bills, or show detail for one
  bills  --fetch [--session] [--chamber] [--type] [--enacted] [--dry-run]
                                        Fetch bills and write as markdown files
  members   [id] --session [--chamber]  List members, or show detail for one
  committees [id] --session [--chamber] List committees, or show detail for one
  sessions                              List all legislative sessions

Examples:
  ./ga-cli code 1-1-1
  ./ga-cli bills --session 1033 --chamber house --type resolution --enacted
  ./ga-cli bills 69281
  ./ga-cli bills --fetch --session 1032 --enacted
  ./ga-cli members --chamber senate
  ./ga-cli committees --session 1033 --chamber house
  ./ga-cli committees 87
  ./ga-cli sessions
"""

import argparse
import os
import sys
import urllib.error

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from ga.legis import Client
from ga.cli.bills import cmd_bills
from ga.cli.code import cmd_code
from ga.cli.committees import cmd_committees
from ga.cli.members import cmd_members
from ga.cli.sessions import cmd_sessions


def main():
    parser = argparse.ArgumentParser(description="Georgia CLI")
    sub = parser.add_subparsers(dest="command", required=False)

    # code
    p = sub.add_parser("code", help="Browse Georgia Code, or fetch OCGA with --fetch")
    p.add_argument("id", nargs="?", help="Title (1), chapter (1-1), or section (1-1-1)")
    p.add_argument("--year", type=int, help="Code year (default: latest)")
    p.add_argument("--fetch", action="store_true", help="Fetch OCGA into ocga/")
    p.add_argument("--title", type=int, help="Fetch only this title number (with --fetch)")
    p.add_argument("--out", help="Output directory (default: ocga/)")
    p.add_argument("--dry-run", action="store_true")
    p.add_argument("--workers", type=int, default=1, help="Parallel chapter workers (default: 1)")
    p.add_argument("--delay", type=float, default=0.2, help="Base delay between requests per worker")

    # bills
    p = sub.add_parser("bills", help="List bills, show detail for one, or fetch to markdown")
    p.add_argument("id", type=int, nargs="?", help="Legislation ID (omit to list)")
    p.add_argument("--session", type=int)
    p.add_argument("--chamber", choices=["house", "senate"])
    p.add_argument("--type", choices=["bill", "resolution"], dest="doc_type")
    p.add_argument("--enacted", action="store_true")
    p.add_argument("--limit", type=int, help="Max results (default: 20)")
    p.add_argument("--all", action="store_true", help="Remove default 20-result limit")
    p.add_argument("--text", action="store_true", help="Fetch and show full bill text")
    p.add_argument("--fetch", action="store_true", help="Write bills to markdown files")
    p.add_argument("--dry-run", action="store_true")
    p.add_argument("--out", help="Output base directory (default: legislation/)")
    p.add_argument("--delay", type=float, default=0.2)

    # members
    p = sub.add_parser("members", help="List members, or show detail for one")
    p.add_argument("id", type=int, nargs="?", help="Member ID (omit to list all)")
    p.add_argument("--session", type=int)
    p.add_argument("--chamber", choices=["house", "senate"])

    # committees
    p = sub.add_parser("committees", help="List committees, or show detail for one")
    p.add_argument("id", type=int, nargs="?", help="Committee ID (omit to list all)")
    p.add_argument("--session", type=int)
    p.add_argument("--chamber", choices=["house", "senate"])

    # sessions
    sub.add_parser("sessions", help="List all legislative sessions")

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        return

    client = Client()
    commands = {
        "code":       cmd_code,
        "bills":      cmd_bills,
        "members":    cmd_members,
        "committees": cmd_committees,
        "sessions":   cmd_sessions,
    }
    try:
        commands[args.command](client, args)
    except urllib.error.HTTPError as e:
        print(f"Error: {'not found' if e.code == 404 else f'HTTP {e.code}'}.", file=sys.stderr)
        sys.exit(1)
    except urllib.error.URLError as e:
        print(f"Error: {e.reason}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
